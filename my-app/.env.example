# =============================================================================
# UAR Portal - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# ALL variables below are REQUIRED for the application to start
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string (TLS enforced)
# Format: postgresql://username:password@host:port/database?schema=public&sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/uar_web?schema=public&sslmode=require"

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
# SMTP server hostname (e.g., smtp.gmail.com, smtp.office365.com) - REQUIRED
SMTP_HOST="smtp.gmail.com"

# SMTP server port (587 for STARTTLS, 465 for SMTPS) - REQUIRED
SMTP_PORT="587"

# SMTP authentication username (usually your email address) - REQUIRED
SMTP_USER="your-email@cpp.edu"

# SMTP authentication password (use app-specific password for Gmail/Office365) - REQUIRED
SMTP_PASSWORD="your-app-password"

# -----------------------------------------------------------------------------
# Email Addresses (OPTIONAL - can be configured in Admin → Settings instead)
# These values are used as fallback if not configured in the database
# -----------------------------------------------------------------------------

# Email address to use in the "From" field (OPTIONAL - see Admin Settings)
EMAIL_FROM="noreply@calpolysoc.org"

# Admin email address for receiving new access request notifications (OPTIONAL - see Admin Settings)
ADMIN_EMAIL="soc@cpp.edu"

# Faculty email for VPN account approval notifications (OPTIONAL - see Admin Settings)
FACULTY_EMAIL="soc@cpp.edu"

# Student director emails - comma-separated list (OPTIONAL - see Admin Settings)
STUDENT_DIRECTOR_EMAILS="director1@cpp.edu,director2@cpp.edu"

# =============================================================================
# LDAP/ACTIVE DIRECTORY CONFIGURATION
# =============================================================================
# LDAP server URL - LDAPS required (StartTLS not currently supported by this build)
# Example: ldaps://kamino.cpp.edu:636
LDAP_URL="ldaps://kamino.cpp.edu:636"

# Distinguished Name (DN) for LDAP bind authentication
# This account needs permission to read/create/modify user accounts
# Example: cn=admin,dc=cpp,dc=edu
LDAP_BIND_DN="cn=admin,dc=cpp,dc=edu"

# Password for the LDAP bind DN account
# CRITICAL: Keep this secure! This account has elevated privileges
LDAP_BIND_PASSWORD="your-ldap-password"

# Base DN for LDAP searches (where users are located in the directory)
# Example: ou=users,dc=cpp,dc=edu or dc=cpp,dc=edu
LDAP_SEARCH_BASE="ou=users,dc=cpp,dc=edu"

# Domain name for user principal names (UPN)
# This is appended to usernames: username@LDAP_DOMAIN
# Example: sdc.cpp or tommy.dev
LDAP_DOMAIN="sdc.cpp"

# Comma-separated list of LDAP groups that are considered domain administrators
# Users in these groups will have admin access to the UAR Portal
# Example: CN=Domain Admins,CN=Administrators,CN=Enterprise Admins
LDAP_ADMIN_GROUPS="CN=Domain Admins,CN=Administrators,CN=Enterprise Admins,CN=Schema Admins"

# LDAP group DN to add newly created users to
# All new accounts will be added to this group automatically
# Example: CN=SDC Users,OU=Groups,DC=cpp,DC=edu
LDAP_GROUP2ADD="CN=SDC Users,OU=Groups,DC=cpp,DC=edu"
LDAP_KAMINO_INTERNAL_GROUP="CN=Internal Users,OU=Groups,DC=cpp,DC=edu"
LDAP_KAMINO_EXTERNAL_GROUP="CN=External Users,OU=Groups,DC=cpp,DC=edu"
LDAP_ALLOW_INVALID_CERTS=false

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Public URL where the application is hosted
# Used for generating links in emails and redirects
# Development: http://localhost:3000
# Production: https://uar.cpp.edu
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret key for NextAuth.js session encryption
# CRITICAL: Generate a secure random string (min 32 characters)
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secure-random-string-here-min-32-chars"

# Secret key for CSRF token generation and validation
# CRITICAL: Generate a secure random string (min 32 characters)
# Run: openssl rand -hex 32
CSRF_SECRET="generate-a-secure-random-hex-string-here-min-64-chars"

# =============================================================================
# CLOUDFLARE TURNSTILE CONFIGURATION
# =============================================================================
# Site Key (Public)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# Secret Key (Private)
TURNSTILE_SECRET_KEY="1x00000000000000000000BB"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Secret key for encrypting sensitive data (passwords) at rest in the database
# CRITICAL: Generate a secure 64-character hex string (min 32 characters)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Do NOT change this after deploying - will break existing encrypted passwords
# WARNING: Do NOT commit this to git - keep in environment variables or secrets manager
ENCRYPTION_SECRET="generate-a-secure-64-char-hex-string-DO-NOT-SHARE"

# Salt for key derivation (used with ENCRYPTION_SECRET)
# CRITICAL: Generate a secure 32-character hex string (min 16 characters)
# Run: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# WARNING: Do NOT change this after deploying - will break existing encrypted passwords
# WARNING: Do NOT commit this to git - keep in environment variables or secrets manager
ENCRYPTION_SALT="generate-a-secure-32-char-hex-string-DO-NOT-SHARE"

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
# Node environment (development, production, test)
# NODE_ENV="development"

# Session token lifetime override (seconds, defaults to 28800 / 8 hours)
# AUTH_SESSION_MAX_AGE="28800"
