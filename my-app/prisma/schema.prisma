generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AccessRequest {
  id                     String                    @id @default(cuid())
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  version                Int                       @default(0)
  name                   String
  email                  String
  isInternal             Boolean
  needsDomainAccount     Boolean
  institution            String?
  eventReason            String?
  eventId                String?
  accessEndTime          DateTime?
  isVerified             Boolean                   @default(false)
  verificationToken      String?                   @unique
  verificationAttempts   Int                       @default(0)
  verifiedAt             DateTime?
  verificationTokenExpiresAt DateTime?
  status                 String                    @default("pending_verification")
  acknowledgedByDirector Boolean                   @default(false)
  acknowledgedAt         DateTime?
  acknowledgedBy         String?
  approvedAt             DateTime?
  approvedBy             String?
  ldapUsername           String?
  vpnUsername            String?
  accountPassword        String?
  accountCreatedAt       DateTime?
  provisioningState      String?
  provisioningStartedAt  DateTime?
  provisioningCompletedAt DateTime?
  provisioningError      String?
  accountExpiresAt       DateTime?
  sentToFacultyAt        DateTime?
  sentToFacultyBy        String?
  rejectedAt             DateTime?
  rejectedBy             String?
  rejectionReason        String?
  approvalMessage        String?
  isGrandfatheredAccount Boolean                   @default(false) // For existing accounts without email
  isManuallyAssigned     Boolean                   @default(false) // Request linked to existing AD account
  manuallyAssignedAt     DateTime?
  manuallyAssignedBy     String?
  linkedAdUsername       String?                                    // The existing AD username this request is linked to
  linkedVpnUsername      String?                                    // The existing VPN username this request is linked to (for external users)
  manualAssignmentNotes  String?                                    // Notes about the manual assignment
  // Account lifecycle tracking
  adAccountStatus        String?                   @default("active") // "active", "disabled", "deleted"
  adDisabledAt           DateTime?
  adDisabledBy           String?
  adDisabledReason       String?
  adEnabledAt            DateTime?
  adEnabledBy            String?
  vpnAccountStatus       String?                   @default("active") // "active", "revoked", "deleted"
  vpnRevokedAt           DateTime?
  vpnRevokedBy           String?
  vpnRevokedReason       String?
  vpnRestoredAt          DateTime?
  vpnRestoredBy          String?
  event                  Event?                    @relation(fields: [eventId], references: [id])
  comments               RequestComment[]
  supportTickets         SupportTicket[]
  activationToken        AccountActivationToken?

  @@index([email])
  @@index([verificationToken])
  @@index([status])
  @@index([eventId])
  @@index([ldapUsername])
  @@index([vpnUsername])
  @@index([isManuallyAssigned])
  @@index([linkedAdUsername])
  @@index([linkedVpnUsername])
  @@index([adAccountStatus])
  @@index([vpnAccountStatus])
  // Removed global unique constraints - usernames can be reused after rejection
  // @@unique([ldapUsername])
  // @@unique([vpnUsername])
  @@unique([linkedAdUsername])
}

model RequestComment {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  comment   String
  author    String
  requestId String
  type      String?
  request   AccessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([createdAt])
}

model Event {
  id             String          @id @default(cuid())
  name           String
  description    String?
  endDate        DateTime?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accessRequests AccessRequest[]

  @@index([isActive])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([tokenHash])
  @@index([expiresAt])
}

model AccountActivationToken {
  id              String        @id @default(cuid())
  accessRequestId String        @unique
  tokenHash       String        @unique
  expiresAt       DateTime
  used            Boolean       @default(false)
  usedAt          DateTime?
  attempts        Int           @default(0)
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  accessRequest   AccessRequest @relation(fields: [accessRequestId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([expiresAt])
  @@index([accessRequestId])
}

model SupportTicket {
  id                 String                    @id @default(cuid())
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  subject            String
  category           String?
  severity           String?
  body               String
  status             String                    @default("open")
  username           String
  closedAt           DateTime?
  closedBy           String?
  relatedRequestId   String?
  relatedRequest     AccessRequest?            @relation(fields: [relatedRequestId], references: [id])
  responses          TicketResponse[]
  statusLogs         TicketStatusLog[]
  batchCreations     BatchAccountCreation[]

  @@index([username])
  @@index([status])
  @@index([createdAt])
  @@index([relatedRequestId])
}

model TicketResponse {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  message   String
  author    String
  isStaff   Boolean       @default(false)
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model TicketStatusLog {
  id         String        @id @default(cuid())
  createdAt  DateTime      @default(now())
  ticketId   String
  oldStatus  String?
  newStatus  String
  changedBy  String
  isStaff    Boolean       @default(false)
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model BatchAccountCreation {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  createdBy           String
  description         String
  totalAccounts       Int
  successfulAccounts  Int                  @default(0)
  failedAccounts      Int                  @default(0)
  status              String               @default("processing")
  completedAt         DateTime?
  linkedTicketId      String?
  linkedTicket        SupportTicket?       @relation(fields: [linkedTicketId], references: [id])
  accounts            BatchAccountItem[]
  auditLogs           BatchAuditLog[]

  @@index([createdBy])
  @@index([createdAt])
  @@index([status])
  @@index([linkedTicketId])
}

model BatchAccountItem {
  id                    String                @id @default(cuid())
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  batchId               String
  batch                 BatchAccountCreation  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  accountType           String                @default("AD") // "AD" or "VPN"
  name                  String
  email                 String?
  ldapUsername          String
  vpnUsername           String?
  password              String
  accountExpiresAt      DateTime?
  isInternal            Boolean               @default(true)
  status                String                @default("pending")
  ldapCreatedAt         DateTime?
  vpnCreatedAt          DateTime?
  errorMessage          String?
  completedAt           DateTime?

  @@index([batchId])
  @@index([status])
  @@index([ldapUsername])
}

model BatchAuditLog {
  id          String                @id @default(cuid())
  createdAt   DateTime              @default(now())
  batchId     String
  batch       BatchAccountCreation  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  action      String
  details     String
  performedBy String
  accountName String?
  success     Boolean

  @@index([batchId])
  @@index([createdAt])
  @@index([performedBy])
}

model VPNAccount {
  id                String              @id @default(cuid())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  username          String              @unique
  name              String
  email             String?
  portalType        String              // "Management", "Limited", "External"
  isInternal        Boolean             @default(false)
  status            String              @default("pending_faculty") // "active", "pending_faculty", "disabled", "revoked"
  expiresAt         DateTime?
  password          String
  createdBy         String
  createdByFaculty  Boolean             @default(false)
  facultyCreatedAt  DateTime?
  disabledAt        DateTime?
  disabledBy        String?
  disabledReason    String?
  revokedAt         DateTime?           // When VPN access was revoked
  revokedBy         String?             // Who revoked access
  revokedReason     String?             // Why it was revoked
  restoredAt        DateTime?           // When VPN access was restored
  restoredBy        String?             // Who restored access
  canRestore        Boolean             @default(true) // Whether account can be restored after revocation
  notes             String?
  batchId           String?
  accessRequestId   String?             // Link to the AccessRequest that created this VPN account
  importId          String?             // Link to the VPNImport that imported this account
  adUsername        String?             // Linked AD account username (for any account tied to an AD user)
  statusLogs        VPNAccountStatusLog[]
  comments          VPNAccountComment[]

  @@index([username])
  @@index([portalType])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@index([accessRequestId])
  @@index([importId])
  @@index([revokedAt])
  @@index([adUsername])
}

model VPNAccountStatusLog {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  accountId   String
  account     VPNAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  oldStatus   String?
  newStatus   String
  changedBy   String
  reason      String?

  @@index([accountId])
  @@index([createdAt])
}

model VPNAccountComment {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  comment   String
  author    String
  accountId String
  type      String?    // Optional: 'admin', 'system', 'note', etc.
  account   VPNAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([createdAt])
}

// VPN Import records - tracks spreadsheet imports of VPN users
model VPNImport {
  id              String              @id @default(cuid())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  userType        String              // "Internal" or "External" - which user type this import is for
  portalType      String?             // "Management" or "Limited" - only for Internal users
  fileName        String              // Original filename of the imported spreadsheet
  importedBy      String              // Admin username who imported
  totalRecords    Int                 // Total records in import
  matchedRecords  Int                 @default(0) // How many have been matched to AD accounts
  processedRecords Int               @default(0) // How many have been processed/created as VPN accounts
  createdAccounts Int                 @default(0) // How many VPN accounts have been created
  status          String              @default("pending") // "pending", "processing", "completed", "failed"
  notes           String?
  processedAt     DateTime?           // When the queue item was fully processed
  expiresAt       DateTime?           // Auto-cleanup timestamp
  importRecords   VPNImportRecord[]

  @@index([portalType])
  @@index([userType])
  @@index([importedBy])
  @@index([createdAt])
  @@index([status])
  @@index([processedAt])
  @@index([expiresAt])
}

// Individual records from VPN import spreadsheets
model VPNImportRecord {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  importId        String
  import          VPNImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  
  // Data from spreadsheet
  vpnUsername     String    // VPN username from spreadsheet
  fullName        String?
  email           String?
  notes           String?
  rawData         String?   // JSON string of all imported fields
  
  // AD Matching
  matchStatus     String    @default("unmatched") // "unmatched", "matched", "no_match", "conflict"
  adUsername      String?   // Matched Active Directory username
  adDisplayName   String?
  adEmail         String?
  adDepartment    String?
  matchedBy       String?   // Admin who performed the match
  matchedAt       DateTime?
  matchNotes      String?
  
  // VPN Account Creation
  vpnAccountCreated Boolean @default(false)
  vpnAccountId      String?
  createdAt_vpn     DateTime?
  
  @@index([importId])
  @@index([vpnUsername])
  @@index([matchStatus])
  @@index([adUsername])
}

model Session {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  username     String
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  lastActivity DateTime  @default(now())
  revokedAt    DateTime?
  ipAddress    String?
  userAgent    String?

  @@index([username])
  @@index([expiresAt])
}

model BlockedEmail {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  email             String    @unique
  reason            String
  notes             String?
  linkedTicketId    String?
  blockedBy         String
  isActive          Boolean   @default(true)
  deactivatedAt     DateTime?
  deactivatedBy     String?
  deactivationNotes String?

  @@index([email])
  @@index([isActive])
  @@index([blockedBy])
  @@index([createdAt])
}

model SystemSettings {
  id                        String    @id @default(cuid())
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  loginDisabled             Boolean   @default(false)
  internalRegistrationDisabled Boolean @default(false)
  externalRegistrationDisabled Boolean @default(false)
  globalNotificationBanner  String?   // Legacy field - use NotificationBanner model instead
  notificationBannerType    String?   // Legacy field - use NotificationBanner model instead
  lastModifiedBy            String?
  manualOverride            Boolean   @default(false) // When true, only DB edit can re-enable logins
  
  // Email Configuration
  emailFrom                 String?   // "From" email address
  adminEmail                String?   // Admin notification email
  facultyEmail              String?   // Faculty approval notification email
  studentDirectorEmails     String?   // Comma-separated list of student director emails

  @@index([loginDisabled])
  @@index([internalRegistrationDisabled])
  @@index([externalRegistrationDisabled])
}

model NotificationBanner {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  message       String
  type          String    // "info", "warning", "error", "success"
  priority      Int       @default(0) // Higher numbers display first
  isActive      Boolean   @default(true)
  startDate     DateTime? // Optional: when to start showing
  endDate       DateTime? // Optional: when to stop showing
  createdBy     String
  dismissible   Boolean   @default(true)

  @@index([isActive])
  @@index([priority])
  @@index([startDate])
  @@index([endDate])
}

model AuditLog {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  action        String    // Action type: "view_page", "create", "update", "delete", "approve", "reject", etc.
  category      String    // Category: "access_request", "event", "user", "batch", "vpn", "support", "settings", "blocklist", "navigation"
  username      String    // Admin who performed the action
  targetId      String?   // ID of the affected resource (if applicable)
  targetType    String?   // Type of target: "AccessRequest", "Event", "User", "Batch", "VPNAccount", "SupportTicket", etc.
  details       String?   // JSON string with additional details about the action
  ipAddress     String?   // IP address of the admin
  userAgent     String?   // Browser/user agent information
  success       Boolean   @default(true) // Whether the action succeeded
  errorMessage  String?   // Error message if action failed

  @@index([username])
  @@index([action])
  @@index([category])
  @@index([createdAt])
  @@index([targetType])
  @@index([success])
}

// Account Lifecycle Management - Track disable/enable operations for AD and VPN accounts
model AccountLifecycleAction {
  id                  String                        @id @default(cuid())
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  actionType          String                        // "disable_ad", "enable_ad", "revoke_vpn", "restore_vpn", "promote_vpn_role", "demote_vpn_role"
  targetAccountType   String                        // "AD", "VPN", "BOTH"
  targetUsername      String                        // The username (AD or VPN) being affected
  targetUserId        String?                       // Link to AccessRequest or VPNAccount ID
  status              String                        @default("processing") // "processing", "completed", "failed", "cancelled"
  reason              String                        // Why the action is being taken
  requestedBy         String                        // Admin username who requested
  requestedAt         DateTime                      @default(now())
  scheduledFor        DateTime?                     // Optional: schedule for future execution
  processedAt         DateTime?
  processedBy         String?                       // System or admin who processed
  completedAt         DateTime?
  errorMessage        String?
  rollbackData        String?                       // JSON string with data needed for rollback
  relatedRequestId    String?                       // Link to AccessRequest if applicable
  relatedTicketId     String?                       // Link to SupportTicket if applicable
  vpnRoleChange       String?                       // For role changes: "Limited->Management", "Management->Limited"
  adDisabled          Boolean                       @default(false) // Track if AD portion completed
  vpnDisabled         Boolean                       @default(false) // Track if VPN portion completed
  canRestore          Boolean                       @default(true)  // Whether this account can be restored
  notes               String?                       // Additional notes
  batchId             String?                       // Link to AccountLifecycleBatch if part of batch
  batch               AccountLifecycleBatch?        @relation(fields: [batchId], references: [id])
  history             AccountLifecycleHistory[]
  adActivityLogs      ADAccountActivityLog[]
  vpnActivityLogs     VPNAccountActivityLog[]
  
  @@index([targetUsername])
  @@index([status])
  @@index([actionType])
  @@index([requestedBy])
  @@index([createdAt])
  @@index([scheduledFor])
  @@index([batchId])
  @@index([relatedRequestId])
  @@index([relatedTicketId])
  @@index([targetUserId])
}

// Batch operations for account lifecycle (e.g., disable multiple accounts at once)
model AccountLifecycleBatch {
  id                  String                      @id @default(cuid())
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  batchType           String                      // "disable", "enable", "role_change"
  description         String
  requestedBy         String
  totalActions        Int
  completedActions    Int                         @default(0)
  failedActions       Int                         @default(0)
  status              String                      @default("pending") // "pending", "processing", "completed", "failed", "partial"
  startedAt           DateTime?
  completedAt         DateTime?
  relatedTicketId     String?
  notes               String?
  actions             AccountLifecycleAction[]
  
  @@index([requestedBy])
  @@index([status])
  @@index([createdAt])
}

// History tracking for all account lifecycle changes
model AccountLifecycleHistory {
  id                  String                    @id @default(cuid())
  createdAt           DateTime                  @default(now())
  actionId            String
  action              AccountLifecycleAction    @relation(fields: [actionId], references: [id], onDelete: Cascade)
  event               String                    // "created", "queued", "processing", "completed", "failed", "cancelled", "rolled_back"
  details             String?                   // JSON string with additional details
  performedBy         String?
  previousStatus      String?
  newStatus           String?
  
  @@index([actionId])
  @@index([createdAt])
}

// VPN Role Management - Track portal type changes (Limited <-> Management)
model VPNRoleChange {
  id                  String      @id @default(cuid())
  createdAt           DateTime    @default(now())
  vpnAccountId        String
  username            String
  previousRole        String      // "Limited", "Management", "External"
  newRole             String      // "Limited", "Management", "External"
  changedBy           String
  reason              String
  relatedActionId     String?     // Link to AccountLifecycleAction if applicable
  notes               String?
  
  @@index([vpnAccountId])
  @@index([username])
  @@index([createdAt])
  @@index([relatedActionId])
}

// AD Account Sync - Automatic synchronization of existing AD accounts with VPN access
model ADAccountSync {
  id                String              @id @default(cuid())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  startedAt         DateTime            @default(now())
  completedAt       DateTime?
  status            String              @default("running") // "running", "completed", "failed", "partial"
  triggeredBy       String              // Admin username who triggered the sync
  
  // Statistics
  totalADAccounts   Int                 @default(0) // Total AD accounts found with @cpp.edu
  totalVPNAccounts  Int                 @default(0) // Total VPN accounts in Limited portal
  matchedAccounts   Int                 @default(0) // Successfully matched accounts
  unmatchedAD       Int                 @default(0) // AD accounts without VPN match
  unmatchedVPN      Int                 @default(0) // VPN accounts without AD match
  autoAssigned      Int                 @default(0) // Access requests automatically assigned
  
  errorMessage      String?             // Error if sync failed
  notes             String?
  matches           ADAccountMatch[]

  @@index([triggeredBy])
  @@index([createdAt])
  @@index([status])
}

// Individual matches found during AD sync
model ADAccountMatch {
  id                String        @id @default(cuid())
  createdAt         DateTime      @default(now())
  syncId            String
  sync              ADAccountSync @relation(fields: [syncId], references: [id], onDelete: Cascade)
  
  // AD Account Info
  adUsername        String        // e.g., "billy"
  adDisplayName     String
  adEmail           String        // e.g., "billy@cpp.edu"
  
  // VPN Account Info (if matched)
  vpnUsername       String?       // e.g., "billy" (from Limited portal)
  vpnAccountId      String?       // Link to VPNAccount if it exists
  
  // Access Request Info (if found)
  accessRequestId   String?       // Link to AccessRequest if found
  requestEmail      String?       // Email from the access request
  requestName       String?       // Name from the access request
  
  // Match Status
  matchType         String        // "full_match", "ad_only", "vpn_only", "no_request"
  wasAutoAssigned   Boolean       @default(false) // Was this automatically assigned to a request?
  assignedAt        DateTime?
  
  notes             String?

  @@index([syncId])
  @@index([adUsername])
  @@index([vpnUsername])
  @@index([accessRequestId])
  @@index([matchType])
}

// AD Account Activity Log - Track all enable/disable actions with lifecycle action references
model ADAccountActivityLog {
  id                  String                      @id @default(cuid())
  createdAt           DateTime                    @default(now())
  accountId           String                      // AccessRequest ID
  accountUsername     String                      // Username at time of action
  accountName         String?                     // Display name at time of action
  accountEmail        String?                     // Email at time of action
  actionType          String                      // "disabled", "enabled"
  performedBy         String                      // Admin username
  reason              String?                     // Why the action was taken
  lifecycleActionId   String?                     // Link to AccountLifecycleAction if applicable
  lifecycleAction     AccountLifecycleAction?     @relation(fields: [lifecycleActionId], references: [id], onDelete: SetNull)
  notes               String?                     // Additional context
  ldapSuccess         Boolean                     @default(false) // Whether LDAP operation succeeded
  ldapError           String?                     // Any LDAP error message

  @@index([accountId])
  @@index([accountUsername])
  @@index([lifecycleActionId])
  @@index([createdAt])
  @@index([performedBy])
}

// VPN Account Activity Log - Track all enable/disable/role changes with lifecycle action references
model VPNAccountActivityLog {
  id                  String                      @id @default(cuid())
  createdAt           DateTime                    @default(now())
  accountId           String                      // VPNAccount ID
  accountUsername     String                      // Username at time of action
  accountName         String                      // Display name at time of action
  accountEmail        String?                     // Email at time of action
  actionType          String                      // "disabled", "enabled", "revoked", "restored", "role_promoted", "role_demoted"
  performedBy         String                      // Admin username
  reason              String?                     // Why the action was taken
  lifecycleActionId   String?                     // Link to AccountLifecycleAction if applicable
  lifecycleAction     AccountLifecycleAction?     @relation(fields: [lifecycleActionId], references: [id], onDelete: SetNull)
  oldPortalType       String?                     // For role changes
  newPortalType       String?                     // For role changes
  notes               String?                     // Additional context

  @@index([accountId])
  @@index([accountUsername])
  @@index([lifecycleActionId])
  @@index([createdAt])
  @@index([performedBy])
}

// AD Account Comments - Comments tied to account ID, not username (to avoid inheritance)
model ADAccountComment {
  id                  String      @id @default(cuid())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  accountId           String      // AccessRequest ID - permanent identifier
  accountUsername     String      // Username at time of comment (for reference)
  comment             String
  author              String      // Admin username
  isInternal          Boolean     @default(false) // Internal admin note vs visible to others
  isPinned            Boolean     @default(false) // Pin important comments
  editedAt            DateTime?
  deletedAt           DateTime?   // Soft delete
  deletedBy           String?

  @@index([accountId])
  @@index([author])
  @@index([createdAt])
  @@index([isPinned])
  @@index([deletedAt])
}

