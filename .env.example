# Database Configuration
DB_PASSWORD=your_secure_database_password_here
DATABASE_URL=postgresql://uar_user:your_secure_database_password_here@postgres:5432/uar_database

# Redis Configuration
REDIS_URL=redis://redis:6379

# Session Configuration
SESSION_SECRET=your_very_long_random_session_secret_at_least_32_characters

# Email/SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# LDAP Configuration (if using LDAP authentication)
LDAP_URL=ldap://your-ldap-server:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=your_ldap_password
LDAP_BASE_DN=dc=example,dc=com

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# Application URL
NEXTAUTH_URL=http://localhost:3000
# For production, use your actual domain:
# NEXTAUTH_URL=https://yourdomain.com

# Node Environment
NODE_ENV=production
